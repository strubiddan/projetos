import pandas as pd
import numpy as np
import yfinance as yf
import requests
import telebot
import threading
import time



chave_bot = '8621180793:AAFNqgM3KBBOfOm4V16849f0oV51TfhYaKU'
bot = telebot.TeleBot(chave_bot)

dic_alerta = {}
########################## DEF (enviar_msg)
def enviar_msg(id_destino,ativo, preco_atual):
        mensagem = f'\U0001F6A8 ALERTA \U0001F6A8\n\U0001F3AF O ativo {ativo} atingiu o preço definido \U0001F3AF\n\U0001F4CA Preço atual do ativo é de R$ {preco_atual:.2f} \U0001F4CA'
        url = f'https://api.telegram.org/bot{chave_bot}/sendMessage?chat_id={id_destino}&text={mensagem}'
        requests.get(url) # O bot envia a mensagem na hora
        
print('funcao1 executada')
lista_ativos = ['PETR4', 'BOVA11','CMIN3']
dic_alvo_high = {'PETR4': 50, 'BOVA11':210,'CMIN3':6} #tenho uma opçao, e quero saber se petr4 vai bater 50 reais, por que se bater eu entro
dic_alvo_low = {'PETR4': 27, 'BOVA11':200,'CMIN3':4}
########################## DEF (buscar_preco)
def buscar_preco():
    for cliente in dic_alerta:
        for alerta in dic_alerta[cliente]:
            ativo =alerta['ativo'] 
            preco_final = alerta['preco']
            ticker = yf.Ticker(ativo + '.SA')
            dados_hj = ticker.history(period="1d")
            preco_atual = float(round(dados_hj['Close'].iloc[-1],2))
            if preco_atual >= preco_final:
                 enviar_msg(cliente,ativo,preco_atual)
            # if preco_atual >= dic_alvo_high[ativo]:
            #     enviar_msg(ativo,preco_atual)
            # elif preco_atual <= dic_alvo_low[ativo]:
            #     enviar_msg(ativo,preco_atual)
print('func2 executada')

########################## DEF (loop_buscar_preco)
def loop_buscar_preco(): 
    while True:
        buscar_preco()
        print('while executado')
        print('Programa em descanso ZZZzzzZZZ')
        time.sleep(60)
        print('sleep executado')
        print('start executado')
####################### COMANDO START
@bot.message_handler(commands=['start'])
def cmd_start(message):# O 'message' aqui é preenchido automaticamente pelo Telegram
    bot.reply_to(message, 'Seja bem-vindo(a) ao bot Sniper da Bovespa!\nNo momento temos apenas 01 (uma) função:\n' \
                '- Alerta de preço alvo para ativos listados na Bovespa:')
 #               'Informe qual ação listada na B3 você deseja criar um alerta.\nExemplo: PETR4')
print('start executado')
####################### COMANDO HELP
@bot.message_handler(commands=['help'])
def cmd_help(message):
    bot.reply_to(message, 'Os comandos disponíveis:\n ' \
    '/help - abrir lista de comandos\n'\
    '/acaoprecoalvo - define um alerta para um ativo\n '\
    'Exemplo: /acaoprecoalvo petr4 35,00'
    )
print('help executado')
###################### COMANDO DEFINIR AÇÃO-PREÇO-ALVO
@bot.message_handler(commands=['acaoprecoalvo'])
def cmd_acaoprecoalvo(message):
    cliente_id = message.chat.id
    partes = message.text.split()
    ativo = partes[1].upper()
    preco_texto = partes[2]
    preco_final = float(preco_texto.replace(',', '.'))
    if cliente_id not in dic_alerta:
        dic_alerta[cliente_id] = []
    ticker = yf.Ticker(f"{ativo}.SA")
    dados = ticker.history(period="1d")
    if dados.empty:
        bot.reply_to(message, f'Erro o ativo {ativo} não existe/ não é listado na Bovespa')
    else:     
        ja_existe = False
        for alerta in dic_alerta[cliente_id]:           
            if alerta['ativo'] == ativo:
                alerta['preco'] = preco_final
                ja_existe = True
                bot.reply_to(message, f'Alerta de {ativo} atualizado para preço alvo de: R${preco_final:.2f}')
                return
        if not ja_existe:        
                novo_alerta = {'ativo': ativo, 'preco': preco_final}
                dic_alerta[cliente_id].append(novo_alerta)
                bot.reply_to(message, f'O ativo {ativo} foi adicionado na lista de ações observadas.\n ' \
                f'Preço alvo: R$ {preco_final:.2f}')   
print(dic_alerta)         
print('acaoprecoalvo executado')
########################## RESPONDER TUDO (OPICIONAL)
@bot.message_handler(func=lambda message: True)
def responder_tudo(message):
    bot.reply_to(message, f"Não consegui compreender sua mensagem. Tente utilizar um comando válido. Para isso você pode utilizar o comando /help")
print('responder tudo executado')

############################ "Thread" para o loop de preços rodar em paralelo
monitor = threading.Thread(target=loop_buscar_preco)
monitor.daemon = True # Faz a busca parar se você fechar o programa
monitor.start() #inicia
buscar_preco() # aqui pra não gerar erro

########################### LIGANDO O BOT 
print('bot ligando')
bot.infinity_polling()
